{
  "manifest_version": 3,
  "name": "Sirr — Ephemeral Secrets",
  "version": "0.1.0",
  "description": "Right-click to store and paste ephemeral secrets via Sirr. Secrets burn after use.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://sirr.sirrlock.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "Sirr — Ephemeral Secrets"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "extension@sirrlock.com",
      "strict_min_version": "109.0"
    }
  }
}
